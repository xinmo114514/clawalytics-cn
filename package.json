{
  "name": "clawalytics",
  "version": "0.6.6",
  "description": "Cost-tracking analytics dashboard for OpenClaw - track AI spending across 100+ models, monitor agents, analyze channels, and manage security",
  "author": "David Novotny",
  "license": "MIT",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "clawalytics": "./bin/clawalytics.js",
    "clawalytics-mcp": "./bin/clawalytics-mcp.js"
  },
  "files": [
    "bin",
    "dist",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"corepack pnpm dev:client\" \"corepack pnpm dev:server\"",
    "dev:client": "vite",
    "dev:server": "node scripts/ensure-native-deps.mjs && tsx watch src/server/index.ts",
    "dev:desktop": "node scripts/ensure-native-deps.mjs && corepack pnpm build && node scripts/run-electron-builder.mjs install-app-deps && electron electron/main.mjs",
    "build": "corepack pnpm build:client && corepack pnpm build:server",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:desktop": "corepack pnpm build && node scripts/run-electron-builder.mjs install-app-deps && node scripts/run-electron-builder.mjs --win portable nsis",
    "start": "node scripts/ensure-native-deps.mjs && node scripts/start-production.mjs",
    "rebuild:native": "node scripts/ensure-native-deps.mjs",
    "postinstall": "node scripts/postinstall.js",
    "preuninstall": "node scripts/preuninstall.js",
    "prepublishOnly": "corepack pnpm build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "framer-motion": "^12.32.0",
    "ws": "^8.19.0",
    "yaml": "^2.7.0"
  },
  "optionalDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-direction": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-day-picker": "9.12.0",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.68.0",
    "react-top-loading-bar": "^3.0.2",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/eslint-plugin-query": "^5.91.2",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/react-router": "^1.141.2",
    "@tanstack/react-router-devtools": "^1.141.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.141.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.0.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.1.2",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.25",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.3.0"
  },
  "keywords": [
    "openclaw",
    "claude-code",
    "claude",
    "anthropic",
    "ai-costs",
    "token-tracking",
    "analytics",
    "openai",
    "llm",
    "api-costs",
    "dashboard",
    "cost-tracking",
    "prompt-caching",
    "agent-monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/clawalytics/clawalytics.git"
  },
  "homepage": "https://github.com/clawalytics/clawalytics#readme",
  "bugs": {
    "url": "https://github.com/clawalytics/clawalytics/issues"
  },
  "build": {
    "appId": "com.clawalytics.desktop",
    "productName": "Clawalytics",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/images/**/*"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": true,
    "win": {
      "icon": "public/images/app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "nsis"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-x64-portable.${ext}"
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-x64-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "better-sqlite3",
      "esbuild",
      "@swc/core"
    ]
  }
}
